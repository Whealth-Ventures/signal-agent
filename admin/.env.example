# Copy to .env.local for local dev. In prod these are set in the Vercel project's
# Environment Variables — see README.md.

# GitHub — fine-grained PAT with Contents: Read & Write on the signal-agent repo
GITHUB_TOKEN=github_pat_...
GITHUB_OWNER=Whealth-Ventures
GITHUB_REPO=signal-agent
GITHUB_BRANCH=main
# Author email recorded on tuning/prompt commits.
GIT_COMMIT_EMAIL=signal-agent@whealthventures.com

# Auth — secret used to sign session JWTs (any random 32+ char string)
AUTH_SECRET=replace-with-a-long-random-string

# Single shared login. Anyone who knows these can sign in.
ADMIN_USER=admin
ADMIN_PWD=replace-with-a-strong-password
