# Copy to .env.local for local dev. In prod these come from Secrets Manager
# (signal-agent/prod/admin-env) via systemd EnvironmentFile — see infra/README.md.

# GitHub — fine-grained PAT with Contents: Read & Write on the signal-agent repo
GITHUB_TOKEN=github_pat_...
GITHUB_OWNER=ashwinknan
GITHUB_REPO=signal-agent
GITHUB_BRANCH=main
# Author email recorded on tuning/prompt commits.
GIT_COMMIT_EMAIL=signal-agent@whealthventures.com

# Auth — secret used to sign session JWTs (any random 32+ char string)
AUTH_SECRET=replace-with-a-long-random-string

# Single shared login. Anyone who knows these can sign in.
ADMIN_USER=admin
ADMIN_PWD=replace-with-a-strong-password

# Slack Events API request signing secret (verifies inbound reaction events).
SLACK_SIGNING_SECRET=

# Feedback events store (S3; replaces Vercel Blob). In prod the EC2 instance
# role grants access — no keys needed here.
FEEDBACK_S3_BUCKET=
AWS_REGION=ap-south-1
