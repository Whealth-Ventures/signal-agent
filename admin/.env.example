# GitHub — fine-grained PAT with Contents: Read & Write on the signal-agent repo
GITHUB_TOKEN=github_pat_...
GITHUB_OWNER=ashwinknan
GITHUB_REPO=signal-agent
GITHUB_BRANCH=main

# Auth — secret used to sign magic-link + session JWTs (any random 32+ char string)
AUTH_SECRET=replace-with-a-long-random-string

# Resend — email service for magic links. https://resend.com (free tier)
RESEND_API_KEY=re_...
# Sender — must be a verified domain on Resend
RESEND_FROM=Signal Agent <admin@yourdomain.com>

# Comma-separated whitelist of emails allowed to sign in
ALLOWED_EMAILS=engineering@2070health.com,partner@2070health.com

# Base URL of this deployment (used in magic-link URLs). Vercel sets VERCEL_URL
# automatically in deployed envs; for local dev set this to http://localhost:3000
APP_URL=http://localhost:3000
