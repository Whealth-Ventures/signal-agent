#!/bin/bash
# signal-agent EC2 bootstrap (Amazon Linux 2023). Runs once at first boot.
# Installs the toolchain, creates the app user/dirs, writes the non-secret deploy
# config, and installs sa-fetch.sh (pulls the built artifact from S3). Deploys
# are PUSH: Jenkins uploads a workspace tarball to S3 and SSM runs sa-fetch.sh +
# deploy/deploy.sh. The box never talks to GitHub.
set -euxo pipefail
exec > >(tee -a /var/log/signal-agent-bootstrap.log) 2>&1

timedatectl set-timezone UTC

# --- toolchain ----------------------------------------------------------------
dnf update -y
dnf install -y git jq tar gzip unzip gcc gcc-c++ make \
  python3.11 python3.11-pip python3.11-devel

# Node 20 (Next 14 needs >=18.17)
curl -fsSL https://rpm.nodesource.com/setup_20.x | bash -
dnf install -y nodejs

# AWS CLI v2 (AL2023 doesn't ship it)
curl -fsSL "https://awscli.amazonaws.com/awscli-exe-linux-x86_64.zip" -o /tmp/awscliv2.zip
unzip -q /tmp/awscliv2.zip -d /tmp
/tmp/aws/install --update
rm -rf /tmp/awscliv2.zip /tmp/aws

# --- swap (build headroom on a 2 GB box) --------------------------------------
if [ ! -f /swapfile ]; then
  dd if=/dev/zero of=/swapfile bs=1M count=2048
  chmod 600 /swapfile
  mkswap /swapfile
  swapon /swapfile
  echo '/swapfile none swap sw 0 0' >> /etc/fstab
fi

# --- app user + dirs ----------------------------------------------------------
id -u ${app_user} &>/dev/null || useradd --system --create-home --shell /bin/bash ${app_user}
mkdir -p ${app_dir}/shared
chown -R ${app_user}:${app_user} ${app_dir}

# --- non-secret deploy config (sourced by all deploy scripts) -----------------
# Values are quoted: this file is `source`d by bash and some values contain
# spaces (e.g. the systemd OnCalendar spec).
cat > /etc/signal-agent.env <<CFG
REGION="${region}"
APP_DIR="${app_dir}"
APP_USER="${app_user}"
AGENT_SECRET="${agent_secret}"
ADMIN_SECRET="${admin_secret}"
FEEDBACK_BUCKET="${feedback_bucket}"
ARTIFACT_KEY="artifacts/signal-agent/latest.tgz"
ADMIN_PORT="${admin_port}"
ADMIN_DOMAIN="${admin_domain}"
DIGEST_POST_AT="${digest_post_at}"
DIGEST_ONCALENDAR="${digest_calendar}"
DIGEST_ONCALENDAR_US="${digest_calendar_us}"
CFG
chmod 644 /etc/signal-agent.env

# --- artifact fetch (PUSH model; the box never talks to GitHub) ----------------
# Downloads a workspace tarball from S3 and extracts it over $APP_DIR/repo.
# data/, .venv, and admin/node_modules are NOT in the tarball, so they survive
# (fast incremental rebuilds; SQLite + Chroma state preserved). Arg 1 overrides
# the S3 key (Jenkins passes a specific commit); default = latest.
cat > /usr/local/bin/sa-fetch.sh <<'FETCH'
#!/bin/bash
set -euo pipefail
source /etc/signal-agent.env
KEY="$${1:-$ARTIFACT_KEY}"
case "$KEY" in
  s3://*) URI="$KEY" ;;
  *)      URI="s3://$FEEDBACK_BUCKET/$KEY" ;;
esac
mkdir -p "$APP_DIR/repo"
aws s3 cp "$URI" /tmp/sa-app.tgz --region "$REGION"
tar -xzf /tmp/sa-app.tgz -C "$APP_DIR/repo"
rm -f /tmp/sa-app.tgz
chown -R "$APP_USER:$APP_USER" "$APP_DIR/repo"
FETCH
chmod 755 /usr/local/bin/sa-fetch.sh

# First fetch + deploy (best-effort; no-op until Jenkins has pushed an artifact).
if /usr/local/bin/sa-fetch.sh 2>/dev/null && [ -x "${app_dir}/repo/deploy/deploy.sh" ]; then
  "${app_dir}/repo/deploy/deploy.sh" || true
fi

%{ if orglife_enabled ~}
# =============================================================================
# orglife-bot co-tenant — a Slack Socket Mode helpdesk that shares this box.
# Separate repo + separate Terraform state; here we only prepare its runtime:
# a dedicated `${orglife_app_user}` user and an ISOLATED Node ${orglife_node_major}
# (the system Node 20 above lacks node:sqlite, which its ticket store needs).
# Deploys are PUSH, same as signal-agent: Jenkins uploads a workspace tarball
# to S3 (artifacts/orglife-bot/) and SSM runs ob-fetch.sh + deploy/deploy.sh.
# The box never talks to GitHub.
# =============================================================================

# Non-secret deploy config sourced by the orglife deploy scripts.
cat > /etc/orglife-bot.env <<CFG
REGION=${region}
APP_DIR=${orglife_app_dir}
APP_USER=${orglife_app_user}
ORGLIFE_SECRET=${orglife_secret}
ARTIFACT_BUCKET=${feedback_bucket}
ARTIFACT_KEY=artifacts/orglife-bot/latest.tgz
NODE_MAJOR=${orglife_node_major}
NODE_BIN=/usr/local/bin/node${orglife_node_major}
CFG
chmod 644 /etc/orglife-bot.env

# Idempotent bootstrap: ensure the isolated Node and the app user/dirs. Safe to
# re-run via SSM (Jenkins calls this before ob-fetch.sh + deploy.sh).
cat > /usr/local/bin/ob-bootstrap.sh <<'BOOT'
#!/bin/bash
set -euo pipefail
source /etc/orglife-bot.env

# 1. Isolated Node (leaves signal-agent's system Node 20 untouched).
if ! "$NODE_BIN" --version >/dev/null 2>&1; then
  base="https://nodejs.org/dist/latest-v$NODE_MAJOR.x"
  file="$(curl -fsSL "$base/" | grep -oE "node-v$NODE_MAJOR\.[0-9]+\.[0-9]+-linux-x64\.tar\.xz" | head -1)"
  test -n "$file"
  curl -fsSL "$base/$file" -o /tmp/node$NODE_MAJOR.tar.xz
  mkdir -p /opt/nodejs && rm -rf /opt/nodejs/node$NODE_MAJOR
  tar -xJf /tmp/node$NODE_MAJOR.tar.xz -C /opt/nodejs
  mv /opt/nodejs/node-v*-linux-x64 /opt/nodejs/node$NODE_MAJOR
  ln -sf /opt/nodejs/node$NODE_MAJOR/bin/node "$NODE_BIN"
  rm -f /tmp/node$NODE_MAJOR.tar.xz
fi

# 2. App user + dirs. data/ persists across redeploys (SQLite ticket store);
#    repo/ is refreshed from the S3 artifact each deploy.
id -u "$APP_USER" &>/dev/null || useradd --system --create-home --shell /bin/bash "$APP_USER"
mkdir -p "$APP_DIR/shared" "$APP_DIR/data" "$APP_DIR/repo"
chown -R "$APP_USER:$APP_USER" "$APP_DIR"
BOOT
chmod 755 /usr/local/bin/ob-bootstrap.sh

# Artifact fetch (PUSH model) — mirrors sa-fetch.sh. Extraction is in place over
# $APP_DIR/repo (tarball excludes node_modules; data/ lives outside repo/).
cat > /usr/local/bin/ob-fetch.sh <<'FETCH'
#!/bin/bash
set -euo pipefail
source /etc/orglife-bot.env
KEY="$${1:-$ARTIFACT_KEY}"
case "$KEY" in
  s3://*) URI="$KEY" ;;
  *)      URI="s3://$ARTIFACT_BUCKET/$KEY" ;;
esac
mkdir -p "$APP_DIR/repo"
aws s3 cp "$URI" /tmp/ob-app.tgz --region "$REGION"
tar -xzf /tmp/ob-app.tgz -C "$APP_DIR/repo"
rm -f /tmp/ob-app.tgz
chown -R "$APP_USER:$APP_USER" "$APP_DIR/repo"
FETCH
chmod 755 /usr/local/bin/ob-fetch.sh

# First bootstrap + fetch + deploy (best-effort; no-op until Jenkins has pushed).
/usr/local/bin/ob-bootstrap.sh || true
if /usr/local/bin/ob-fetch.sh 2>/dev/null && [ -x "${orglife_app_dir}/repo/deploy/deploy.sh" ]; then
  "${orglife_app_dir}/repo/deploy/deploy.sh" || true
fi
%{ endif ~}
