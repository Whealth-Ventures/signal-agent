# Copy this file to .env and fill in real values. .env is gitignored.
# In the AWS deployment these are provided from Secrets Manager
# (signal-agent/prod/agent-env) via systemd EnvironmentFile — see infra/README.md.

# --- LLM providers ---
OPENAI_API_KEY=
PERPLEXITY_API_KEY=
# Optional: routes the single ranking call to Claude; falls back to Perplexity if unset.
ANTHROPIC_API_KEY=

# --- Slack delivery ---
SLACK_WEBHOOK_URL=
SLACK_CHANNEL_LABEL=
# Optional: bot-token path (captures a message ts so reactions can be linked).
SLACK_BOT_TOKEN=
SLACK_CHANNEL_ID=

# --- Feedback loop (S3-backed; replaces Vercel Blob) ---
FEEDBACK_S3_BUCKET=
AWS_REGION=ap-south-1
